---
const links = [
  { href: '/', label: 'Inicio' },
  { href: '/sistemas', label: 'Sistemas' },
  { href: '/formacion', label: 'Formación' },
  { href: '/catalogo', label: 'Catálogo' },
  { href: '/contacto', label: 'Contacto' },
];
---
<header class="bg-white border-b border-blue-pale sticky top-0 z-50">
  <div class="max-w-7xl mx-auto px-6 flex items-center justify-between h-20">
    <a href="/" class="flex items-center gap-3">
      <img src="/arias_group_logo.svg" alt="Arias Group Caribe" class="h-12 w-auto" />
    </a>
    <nav class="hidden md:flex items-center gap-8">
      {links.map(l => (
        <a href={l.href} class="text-sm font-medium text-stone-blue hover:text-navy transition-colors">
          {l.label}
        </a>
      ))}
      {/* Slot reservado para redes sociales — pendiente handles oficiales */}
      <div class="flex items-center gap-3" data-social-slot></div>
      <a href="https://wa.me/18494754442" target="_blank" rel="noopener" class="bg-navy text-white px-5 py-2.5 text-sm font-semibold hover:bg-blue transition-colors inline-flex items-center gap-2">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.5 14.4c-.3-.1-1.7-.8-2-.9-.3-.1-.5-.1-.7.1-.2.3-.8.9-1 1.1-.2.2-.4.2-.7.1-.3-.1-1.2-.4-2.3-1.4-.9-.8-1.4-1.7-1.6-2-.2-.3 0-.5.1-.6.1-.1.3-.3.4-.5.1-.2.2-.3.3-.5.1-.2 0-.4 0-.5 0-.1-.7-1.7-1-2.3-.3-.6-.5-.5-.7-.5h-.6c-.2 0-.5.1-.8.4-.3.3-1 1-1 2.4s1 2.8 1.2 3c.1.2 2.1 3.2 5.1 4.5.7.3 1.3.5 1.7.6.7.2 1.4.2 1.9.1.6-.1 1.7-.7 2-1.4.2-.7.2-1.2.2-1.4-.1-.2-.3-.3-.6-.4zM12 2C6.5 2 2 6.5 2 12c0 1.8.5 3.4 1.3 4.8L2 22l5.3-1.4c1.4.8 3 1.2 4.7 1.2 5.5 0 10-4.5 10-10S17.5 2 12 2zm0 18.2c-1.6 0-3-.4-4.3-1.2l-.3-.2-3.1.8.8-3-.2-.3C4 15 3.5 13.5 3.5 12c0-4.7 3.8-8.5 8.5-8.5s8.5 3.8 8.5 8.5-3.8 8.2-8.5 8.2z"/></svg>
        Escribir por WhatsApp
      </a>
    </nav>
    <button id="menu-toggle" class="md:hidden text-navy" aria-label="Abrir menú">
      <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
    </button>
  </div>
  <div id="mobile-menu" class="hidden md:hidden border-t border-blue-pale bg-white">
    {links.map(l => (
      <a href={l.href} class="block px-6 py-4 text-sm font-medium text-ink border-b border-blue-pale">{l.label}</a>
    ))}
  </div>
</header>
<script>
  const btn = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => menu?.classList.toggle('hidden'));
</script>
