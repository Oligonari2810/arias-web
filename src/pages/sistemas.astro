---
import Layout from '../layouts/Layout.astro';

const heroImg = 'https://images.unsplash.com/photo-1541888946425-d81bb19240f5?w=2400&auto=format&fit=crop&q=80';

const sistemas = [
  {
    n: '01',
    t: 'Placas Gypsotech',
    sub: 'STD · Aqua H2 · EXTERNA Light · GypsoLIGNUM',
    d: 'Placas de cartón-yeso para tabiquería interior, zonas húmedas, fachadas ligeras y estructuras de madera. 61 formatos en catálogo con marcado CE y trazabilidad de lote.'
  },
  {
    n: '02',
    t: 'Morteros SATE — Fassatherm',
    sub: 'Sistema integral de aislamiento térmico por el exterior',
    d: 'Adhesivo de aislante, malla de fibra de vidrio, mortero base, imprimación y acabado — todos bajo marca Fassa Bortolo. Un sistema, una sola responsabilidad técnica.'
  },
  {
    n: '03',
    t: 'Perfilería galvanizada',
    sub: 'Z1 · Z2 · galvanizado Z275',
    d: 'Perfiles para subestructura de tabiquería y trasdosados. Z275 para zonas costeras con alta salinidad (Punta Cana, Puerto Plata, Cap Cana).'
  },
  {
    n: '04',
    t: 'Pastas y juntas',
    sub: 'Fassajoint · Gypsofiller · Gypsomaf',
    d: 'Tratamiento de juntas, remate y acabados finales. Formulaciones específicas para humedad tropical.'
  },
  {
    n: '05',
    t: 'Accesorios y cintas',
    sub: 'Cintas de juntas, malla externa, cantoneras, banda estanca',
    d: 'Complementos que cierran el sistema. Aporta integridad del conjunto y durabilidad frente a movimientos estructurales.'
  },
  {
    n: '06',
    t: 'Tornillería y trampillas',
    sub: 'Fijación especializada y registros',
    d: 'Tornillos de punta clavo y brocca para cada tipo de soporte. Trampillas de registro con acabado enrasable.'
  },
];
---
<Layout
  title="Sistemas constructivos Fassa · Arias Group Caribe"
  description="Sistemas completos Fassa Bortolo distribuidos en República Dominicana: placas Gypsotech, morteros SATE Fassatherm, perfilería, pastas, accesorios."
>
  <section class="relative h-[60vh] min-h-[480px] overflow-hidden">
    <img src={heroImg} alt="" class="absolute inset-0 w-full h-full object-cover" />
    <div class="absolute inset-0 bg-gradient-to-b from-navy/40 via-navy/60 to-navy/90"></div>
    <div class="relative z-10 h-full max-w-7xl mx-auto px-6 flex flex-col justify-end pb-20">
      <div class="max-w-3xl">
        <p class="text-xs tracking-[0.3em] uppercase text-sky-pale font-semibold mb-6">Portafolio técnico</p>
        <h1 class="text-white text-5xl md:text-6xl leading-[1.02]" style="font-family: 'Fraunces', serif; font-weight: 400;">
          Seis familias de sistemas. <em class="italic text-sky-pale font-normal">195 referencias.</em>
        </h1>
        <p class="text-lg md:text-xl text-sky-pale max-w-2xl leading-relaxed mt-6">
          Todos fabricados por Fassa Bortolo con marcado CE y trazabilidad de lote. Especificación y suministro gestionados por nuestro equipo técnico.
        </p>
      </div>
    </div>
  </section>

  <section class="max-w-7xl mx-auto px-6 py-24">
    <div class="grid md:grid-cols-2 gap-12 gap-y-16">
      {sistemas.map(s => (
        <div class="border-t border-navy pt-6">
          <span class="text-xs font-mono tracking-widest text-stone-blue">{s.n}</span>
          <h2 class="text-3xl mt-3 mb-2" style="font-family: 'Fraunces', serif; font-weight: 500;">{s.t}</h2>
          <p class="text-sm text-blue mb-5 font-medium">{s.sub}</p>
          <p class="text-base text-ink leading-relaxed">{s.d}</p>
        </div>
      ))}
    </div>
  </section>

  <section class="bg-navy text-white">
    <div class="max-w-5xl mx-auto px-6 py-24 text-center">
      <h2 class="text-3xl md:text-5xl mb-6 leading-tight" style="font-family: 'Fraunces', serif; font-weight: 400;">
        ¿Necesitas especificar un sistema <em class="italic text-sky-pale font-normal">para tu proyecto?</em>
      </h2>
      <p class="text-lg text-sky-pale max-w-2xl mx-auto mb-10 leading-relaxed">
        Envíanos planos o descripción del proyecto. Nuestro equipo técnico te propone el sistema Fassa adecuado en 48 horas.
      </p>
      <a href="https://wa.me/18494754442" target="_blank" rel="noopener" class="inline-flex items-center gap-2 bg-white text-navy px-10 py-5 text-sm font-semibold tracking-wider hover:bg-sky-pale transition-colors">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.5 14.4c-.3-.1-1.7-.8-2-.9-.3-.1-.5-.1-.7.1-.2.3-.8.9-1 1.1-.2.2-.4.2-.7.1-.3-.1-1.2-.4-2.3-1.4-.9-.8-1.4-1.7-1.6-2-.2-.3 0-.5.1-.6.1-.1.3-.3.4-.5.1-.2.2-.3.3-.5.1-.2 0-.4 0-.5 0-.1-.7-1.7-1-2.3-.3-.6-.5-.5-.7-.5h-.6c-.2 0-.5.1-.8.4-.3.3-1 1-1 2.4s1 2.8 1.2 3c.1.2 2.1 3.2 5.1 4.5.7.3 1.3.5 1.7.6.7.2 1.4.2 1.9.1.6-.1 1.7-.7 2-1.4.2-.7.2-1.2.2-1.4-.1-.2-.3-.3-.6-.4zM12 2C6.5 2 2 6.5 2 12c0 1.8.5 3.4 1.3 4.8L2 22l5.3-1.4c1.4.8 3 1.2 4.7 1.2 5.5 0 10-4.5 10-10S17.5 2 12 2zm0 18.2c-1.6 0-3-.4-4.3-1.2l-.3-.2-3.1.8.8-3-.2-.3C4 15 3.5 13.5 3.5 12c0-4.7 3.8-8.5 8.5-8.5s8.5 3.8 8.5 8.5-3.8 8.2-8.5 8.2z"/></svg>
        Consultar sistema
      </a>
    </div>
  </section>
</Layout>
