---
import Layout from '../layouts/Layout.astro';

const heroImg = 'https://images.unsplash.com/photo-1486406146926-c627a92ad1ab?w=2400&auto=format&fit=crop&q=80';
---
<Layout
  title="Contacto · Arias Group Caribe"
  description="Escríbenos por WhatsApp, email o visítanos en nuestro showroom técnico en Santo Domingo, República Dominicana."
>
  <section class="relative h-[50vh] min-h-[420px] overflow-hidden">
    <img src={heroImg} alt="Oficinas y showroom técnico de Arias Group Caribe en Santo Domingo" class="absolute inset-0 w-full h-full object-cover" loading="eager" />
    <div class="absolute inset-0 bg-gradient-to-b from-navy/50 via-navy/65 to-navy/90"></div>
    <div class="relative z-10 h-full max-w-7xl mx-auto px-6 flex flex-col justify-end pb-16">
      <p class="text-xs tracking-[0.3em] uppercase text-sky-pale font-semibold mb-4">Contacto</p>
      <h1 class="text-white text-5xl md:text-6xl leading-tight max-w-3xl" style="font-family: 'Fraunces', serif; font-weight: 400;">
        Cuéntanos el proyecto.<br/>
        <em class="italic text-sky-pale font-normal">Te respondemos hoy.</em>
      </h1>
    </div>
  </section>

  <section class="max-w-6xl mx-auto px-6 py-24">
    <div class="grid md:grid-cols-2 gap-12">
      <div>
        <p class="text-xs tracking-[0.3em] uppercase text-stone-blue font-semibold mb-6">Canal directo</p>
        <h2 class="text-3xl md:text-4xl mb-6 leading-tight" style="font-family: 'Fraunces', serif; font-weight: 500;">
          WhatsApp es el canal <em class="italic text-blue font-normal">más rápido.</em>
        </h2>
        <p class="text-base text-ink leading-relaxed mb-10">
          Envíanos planos, especificaciones o una descripción del proyecto. Nuestro equipo técnico responde el mismo día y devuelve presupuesto detallado en 48 horas.
        </p>
        <div class="flex flex-col gap-4">
          <a href="https://wa.me/18494754442" target="_blank" rel="noopener" class="inline-flex items-center gap-3 bg-navy text-white px-8 py-4 text-sm font-semibold tracking-wide hover:bg-blue transition-colors w-fit">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.5 14.4c-.3-.1-1.7-.8-2-.9-.3-.1-.5-.1-.7.1-.2.3-.8.9-1 1.1-.2.2-.4.2-.7.1-.3-.1-1.2-.4-2.3-1.4-.9-.8-1.4-1.7-1.6-2-.2-.3 0-.5.1-.6.1-.1.3-.3.4-.5.1-.2.2-.3.3-.5.1-.2 0-.4 0-.5 0-.1-.7-1.7-1-2.3-.3-.6-.5-.5-.7-.5h-.6c-.2 0-.5.1-.8.4-.3.3-1 1-1 2.4s1 2.8 1.2 3c.1.2 2.1 3.2 5.1 4.5.7.3 1.3.5 1.7.6.7.2 1.4.2 1.9.1.6-.1 1.7-.7 2-1.4.2-.7.2-1.2.2-1.4-.1-.2-.3-.3-.6-.4zM12 2C6.5 2 2 6.5 2 12c0 1.8.5 3.4 1.3 4.8L2 22l5.3-1.4c1.4.8 3 1.2 4.7 1.2 5.5 0 10-4.5 10-10S17.5 2 12 2zm0 18.2c-1.6 0-3-.4-4.3-1.2l-.3-.2-3.1.8.8-3-.2-.3C4 15 3.5 13.5 3.5 12c0-4.7 3.8-8.5 8.5-8.5s8.5 3.8 8.5 8.5-3.8 8.2-8.5 8.2z"/></svg>
            +1 849 475 4442
          </a>
          <a href="mailto:info@ariasgroupcaribe.com" class="inline-flex items-center gap-3 border border-navy text-navy px-8 py-4 text-sm font-semibold tracking-wide hover:bg-navy hover:text-white transition-colors w-fit">
            info@ariasgroupcaribe.com
          </a>
        </div>
      </div>

      <div class="bg-gray-faint p-10 border-t-4 border-blue">
        <p class="text-xs tracking-[0.3em] uppercase text-stone-blue font-semibold mb-6">Showroom y oficinas</p>
        <h3 class="text-2xl mb-6" style="font-family: 'Fraunces', serif; font-weight: 500;">Arias Group Caribe SRL</h3>
        <ul class="space-y-3 text-base text-ink leading-relaxed">
          <li>Av. Independencia Km 6</li>
          <li>Plaza Comercial Átala I, Suite 203</li>
          <li>Santo Domingo, D.N.</li>
          <li class="pt-2 text-sm text-stone-blue">RNC 1-33-63109-1</li>
        </ul>
        <div class="mt-8 pt-8 border-t border-sky-pale">
          <p class="text-xs tracking-[0.3em] uppercase text-stone-blue font-semibold mb-3">Horario</p>
          <p class="text-sm text-ink">Lunes a viernes · 8:30 a 17:30</p>
          <p class="text-sm text-ink">Sábados · 9:00 a 13:00</p>
        </div>
      </div>
    </div>
  </section>
</Layout>
