---
const imgBase = '/images/arias-realestate';

const heroSlides = [
  { src: `${imgBase}/hero-caribe-masterplan.png`, alt: 'Desarrollo costero Caribe' },
  { src: `${imgBase}/villa-caribe-lujo.png`, alt: 'Villa moderna en el Caribe' },
  { src: `${imgBase}/resort-caribe-01.png`, alt: 'Resort en el Caribe' },
  { src: `${imgBase}/resort-piscina-caribe.png`, alt: 'Piscina de resort en el Caribe' },
];

const businessLines = [
  {
    id: 'pipeline',
    title: 'Desarrollo',
    desc: 'Estructuramos proyectos desde la viabilidad hasta la ejecución. Definimos concepto, estrategia y modelo económico.',
    img: `${imgBase}/selector-desarrollo.png`,
  },
  {
    id: 'pipeline',
    title: 'Ejecución',
    desc: 'Coordinamos y controlamos la ejecución del proyecto. Alineamos equipos, costes, plazos y calidad.',
    img: `${imgBase}/selector-control-ejecucion.png`,
  },
  {
    id: 'inversion',
    title: 'Inversión',
    desc: 'Participamos en proyectos mediante JV, equity o estructuración financiera. Alineamos capital con proyectos viables.',
    img: `${imgBase}/selector-inversion.png`,
  },
];

const audiences = [
  {
    title: 'Inversores',
    text: 'Decidimos dónde invertir y dónde no.',
    img: `${imgBase}/audience-inversores.png`,
  },
  {
    title: 'Desarrolladores',
    text: 'Estructuramos proyectos para que funcionen.',
    img: `${imgBase}/audience-desarrolladores.png`,
  },
  {
    title: 'Constructoras',
    text: 'Ordenamos proyectos para que se puedan ejecutar.',
    img: `${imgBase}/audience-constructoras.png`,
  },
  {
    title: 'Propietarios',
    text: 'Representamos sus intereses dentro del proyecto.',
    img: `${imgBase}/audience-propietarios.png`,
  },
];

const pipelinePhases = [
  ['01', 'Decisión', 'Toma de Decisión', 'Reuniones estratégicas para evaluar oportunidades.', `${imgBase}/selector-desarrollo.png`],
  ['02', 'Viabilidad', 'Análisis / Viabilidad', 'Análisis técnico, financiero y de mercado antes de invertir.', `${imgBase}/pipeline-02-analisis-viabilidad.png`],
  ['03', 'Estrategia', 'Visión Estratégica', 'Identificamos el potencial y definimos la mejor estrategia.', `${imgBase}/hero-caribe-masterplan.png`],
  ['04', 'Estructuración', 'Estructuración del Proyecto', 'Convertimos una idea en un plan realista y ejecutable.', `${imgBase}/selector-inversion.png`],
  ['05', 'Ejecución', 'Control en Obra', 'Supervisión y control para asegurar calidad, plazo y coste.', `${imgBase}/selector-control-ejecucion.png`],
  ['06', 'Entrega', 'Entrega y Resultados', 'Entregamos proyectos que generan valor real y duradero.', `${imgBase}/resort-caribe-01.png`],
];

const pipelineLayers = [
  ['Coordinación de Equipos', 'Alineamos a todos los actores para que el proyecto funcione.', `${imgBase}/hero-caribe-masterplan.png`],
  ['Gestión de Riesgos', 'Anticipamos riesgos y tomamos decisiones para proteger la inversión.', `${imgBase}/selector-control-ejecucion.png`],
  ['Seguimiento y Reporting', 'Información clara y actualizada para decisiones acertadas.', `${imgBase}/selector-inversion.png`],
  ['Relación con Inversores', 'Transparencia y comunicación constante con nuestros inversores.', `${imgBase}/comercial-caribe.png`],
];

const projects = [
  ['hospitality', 'Resort 5 Estrellas', 'Cap Cana · Hospitality', `${imgBase}/resort-caribe-01.png`],
  ['residencial', 'Edificio Residencial', 'Punta Cana · Residencial', `${imgBase}/residencial-caribe.png`],
  ['hospitality', 'Hotel Boutique', 'Samaná · Hospitality', `${imgBase}/resort-piscina-caribe.png`],
  ['commercial', 'Centro Comercial', 'Santo Domingo · Comercial', `${imgBase}/comercial-caribe.png`],
  ['residencial', 'Villas de Lujo', 'Miches · Residencial', `${imgBase}/villa-caribe-lujo.png`],
  ['hospitality', 'Resort All-Inclusive', 'Bayahíbe · Hospitality', `${imgBase}/hero-caribe-masterplan.png`],
];
---
<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="Arias Group Caribe estructura, desarrolla y controla proyectos inmobiliarios en el Caribe." />
    <link rel="icon" type="image/svg+xml" href="/arias_group_logo.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Playfair+Display:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet" />
    <title>ARIAS GROUP CARIBE</title>
  </head>
  <body>
    <div class="scroll-progress" id="scrollProgress"></div>

    <header class="nav" id="mainNav">
      <a class="nav-logo" href="/" aria-label="Arias Group Caribe">
        <img src="/arias_group_logo.svg" alt="Arias Group Caribe" />
      </a>
      <nav class="nav-links" aria-label="Principal">
        <a href="#selector">Qué hacemos</a>
        <a href="#para-quien">Para quién</a>
        <a href="#pipeline">Pipeline</a>
        <a href="#caso">Caso real</a>
        <a href="#proyectos">Proyectos</a>
        <a href="#inversion">Inversión</a>
      </nav>
      <button class="nav-hamburger" id="hamburger" aria-label="Abrir menú" aria-expanded="false">
        <span></span><span></span><span></span>
      </button>
    </header>

    <div class="mobile-menu" id="mobileMenu">
      <a href="#selector">Qué hacemos</a>
      <a href="#para-quien">Para quién</a>
      <a href="#pipeline">Pipeline</a>
      <a href="#caso">Caso real</a>
      <a href="#proyectos">Proyectos</a>
      <a href="#inversion">Inversión</a>
    </div>

    <main>
      <section class="hero">
        <div class="hero-slides">
          {heroSlides.map((slide, index) => (
            <div class:list={['hero-slide', { active: index === 0 }]}>
              <img src={slide.src} alt={slide.alt} loading={index === 0 ? 'eager' : 'lazy'} />
            </div>
          ))}
        </div>
        <div class="hero-overlay"></div>
        <div class="hero-content reveal visible">
          <div class="hero-line"></div>
          <p class="hero-overline">ARIAS GROUP CARIBE</p>
          <h1>Decisión, estructuración y control de activos inmobiliarios en el <em>Caribe</em></h1>
          <p class="hero-subtitle">Convertimos oportunidades de inversión en proyectos viables, estructurados y ejecutables.</p>
          <a href="#selector" class="hero-cta">Cómo trabajamos</a>
        </div>
        <div class="hero-dots" aria-label="Cambiar imagen principal">
          {heroSlides.map((_, index) => (
            <button class:list={['hero-dot', { active: index === 0 }]} data-slide={index} aria-label={`Imagen ${index + 1}`}></button>
          ))}
        </div>
      </section>

      <section class="section-block" id="selector">
        <div class="section-head reveal">
          <div class="section-divider"></div>
          <p class="section-label">Nuestro alcance</p>
          <h2>Cómo operamos</h2>
          <p>Tres líneas de trabajo integradas para llevar oportunidades inmobiliarias de la decisión a la ejecución.</p>
        </div>
        <div class="selector-grid reveal">
          {businessLines.map((line) => (
            <a class="selector-card" href={`#${line.id}`}>
              <img src={line.img} alt={line.title} loading="lazy" />
              <span class="selector-overlay">
                <span class="selector-title">{line.title}</span>
                <span class="selector-desc">{line.desc}</span>
                <span class="selector-arrow">Explorar</span>
              </span>
            </a>
          ))}
        </div>
      </section>

      <section class="audience-section" id="para-quien">
        <div class="audience-inner">
          <div class="section-head reveal">
            <div class="section-divider"></div>
            <p class="section-label">Clientes</p>
            <h2>Para quién trabajamos</h2>
            <p>Trabajamos con quienes tienen decisión sobre el capital y el activo.</p>
          </div>
          <div class="audience-grid">
            {audiences.map((audience) => (
              <article class="audience-card reveal">
                <img src={audience.img} alt={`${audience.title}: ${audience.text}`} loading="lazy" />
              </article>
            ))}
          </div>
        </div>
      </section>

      <section class="pipeline-section" id="pipeline">
        <div class="section-inner">
          <div class="section-head section-head-dark reveal">
            <div class="section-divider"></div>
            <p class="section-label">Proceso</p>
            <h2>Pipeline de trabajo</h2>
            <p>6 fases principales desde la decisión hasta la entrega, con capas de control presentes durante todo el proceso.</p>
          </div>
          <div class="pipeline-grid">
            {pipelinePhases.map(([n, phase, title, desc, img]) => (
              <article class="pipeline-card reveal">
                <div class="pipeline-copy">
                  <span>{n}. {phase}</span>
                  <strong>{title}</strong>
                  <p>{desc}</p>
                </div>
                <img src={img} alt={title} loading="lazy" />
              </article>
            ))}
          </div>
          <div class="pipeline-layers reveal">
            <div class="pipeline-layers-head">
              <p class="section-label">Capas transversales</p>
              <h3>Control durante todo el proceso</h3>
            </div>
            <div class="pipeline-layer-grid">
              {pipelineLayers.map(([title, desc, img]) => (
                <article class="pipeline-layer-card">
                  <img src={img} alt={title} loading="lazy" />
                  <div>
                    <strong>{title}</strong>
                    <p>{desc}</p>
                  </div>
                </article>
              ))}
            </div>
          </div>
        </div>
      </section>

      <section class="section-block" id="caso">
        <div class="split reveal">
          <div>
            <div class="section-divider"></div>
            <p class="section-label align-left">Caso real</p>
            <h2>Masterplan residencial-hotelería</h2>
            <div class="tipo-selector">
              <button class="tipo-btn active" data-tipo="residencial">Residencial</button>
              <button class="tipo-btn" data-tipo="hoteleria">Hotelería</button>
              <button class="tipo-btn" data-tipo="comercial">Comercial</button>
            </div>
            <h3 id="casoTitle">Residencial de Lujo</h3>
            <p id="casoDesc">Desarrollo de villas y apartamentos frente al mar con amenidades premium. Masterplan integrado con acceso directo a playa, zonas verdes y espacios comunes de alto estándar.</p>
            <div class="stats">
              <div><strong id="stat1">120</strong><span id="statLabel1">Unidades</span></div>
              <div><strong id="stat2">45%</strong><span id="statLabel2">ROI estimado</span></div>
              <div><strong id="stat3">18</strong><span id="statLabel3">Meses ejecución</span></div>
            </div>
            <a href="/contacto" class="btn-secondary">Evaluar mi terreno</a>
          </div>
          <img class="case-image" src={`${imgBase}/hero-caribe-masterplan.png`} alt="Masterplan residencial hotelero" loading="lazy" />
        </div>
      </section>

      <section class="section-band" id="proyectos">
        <div class="section-inner">
          <div class="section-head reveal">
            <div class="section-divider"></div>
            <p class="section-label">Portfolio</p>
            <h2>Proyectos</h2>
            <p>Tipologías que desarrollamos en el Caribe.</p>
          </div>
          <div class="filters reveal">
            <button class="filter-btn active" data-filter="all">Todos</button>
            <button class="filter-btn" data-filter="residencial">Residencial</button>
            <button class="filter-btn" data-filter="commercial">Comercial</button>
            <button class="filter-btn" data-filter="hospitality">Hospitality</button>
          </div>
          <div class="projects-grid">
            {projects.map(([category, title, place, img]) => (
              <article class="project-card reveal" data-category={category}>
                <img src={img} alt={title} loading="lazy" />
                <div>
                  <h3>{title}</h3>
                  <p>{place}</p>
                </div>
              </article>
            ))}
          </div>
        </div>
      </section>

      <section class="section-band section-band-blue" id="inversion">
        <div class="section-inner">
          <div class="section-head reveal">
            <div class="section-divider"></div>
            <p class="section-label">Datos</p>
            <h2>Inversión</h2>
            <p>Métricas que respaldan nuestra capacidad de ejecución.</p>
          </div>
          <div class="investment-grid">
            <article><strong class="counter" data-target="650">0</strong><span>Millones USD en proyectos</span><p>Capital gestionado en proyectos ejecutados en Europa y el Caribe.</p></article>
            <article><strong class="counter" data-target="90">0</strong><span>Proyectos completados</span><p>Entregas exitosas en hospitality, residencial y desarrollos mixtos.</p></article>
            <article><strong class="counter" data-target="20">0</strong><span>Años de experiencia</span><p>Trayectoria del equipo directivo en desarrollo, estructuración y control de proyectos.</p></article>
          </div>
          <div class="chart reveal" aria-label="Distribución por sector">
            {[
              ['Hospitality', '40%', '80%'],
              ['Residencial', '35%', '70%'],
              ['Comercial', '15%', '30%'],
              ['Mixed-use', '10%', '20%'],
            ].map(([label, value, height]) => (
              <div class="bar-group">
                <span>{value}</span>
                <div class="bar" style={`--bar-height:${height}`}></div>
                <small>{label}</small>
              </div>
            ))}
          </div>
          <p class="center"><a href="/contacto" class="btn-secondary">Solicitar análisis</a></p>
        </div>
      </section>

      <section class="cta-final">
        <div class="reveal">
          <h2>¿Tienes un proyecto que necesita estructura?</h2>
          <p>Hablemos. Evaluamos tu oportunidad con criterio de inversor y capacidad de ejecución real.</p>
          <a href="/contacto">Contactar</a>
        </div>
      </section>

      <section class="central-message">
        <blockquote>"No vendemos promesas. Vendemos certeza antes del primer dólar invertido. Y si ya invertiste, vendemos recuperación de control y confianza."</blockquote>
        <p>ARIAS GROUP CARIBE</p>
      </section>
    </main>

    <footer>
      <img src="/arias_group_logo.svg" alt="Arias Group Caribe" />
      <span>© 2026 Arias Group Caribe. Todos los derechos reservados.</span>
    </footer>

    <style>
      :root {
        --navy: #1a3557;
        --blue: #2563a8;
        --blue-pale: #eef3f9;
        --gray-faint: #f5f7fa;
        --ink: #1c2b3a;
        --stone: #5c7a99;
        --sky-pale: #c5d5e8;
        --white: #ffffff;
      }
      * { box-sizing: border-box; }
      html { scroll-behavior: smooth; }
      body { margin: 0; font-family: Inter, system-ui, sans-serif; color: var(--ink); line-height: 1.7; overflow-x: hidden; }
      img { max-width: 100%; display: block; }
      a { color: inherit; }
      .scroll-progress { position: fixed; inset: 0 auto auto 0; height: 2px; width: 0; background: var(--blue); z-index: 1001; }
      .nav { position: fixed; inset: 0 0 auto; z-index: 1000; display: flex; align-items: center; justify-content: space-between; padding: 1.15rem 3rem; transition: all .3s ease; }
      .nav.scrolled { background: var(--white); border-bottom: 1px solid var(--sky-pale); padding-block: .85rem; }
      .nav-logo { display: inline-flex; align-items: center; justify-content: center; width: 118px; min-height: 46px; padding: .35rem .55rem; border-radius: 2px; background: rgba(255, 255, 255, .92); text-decoration: none; transition: background .3s ease, transform .3s ease; }
      .nav-logo:hover { transform: translateY(-1px); }
      .nav-logo img { width: 100%; height: auto; display: block; }
      .nav.scrolled .nav-logo { background: transparent; padding-inline: 0; }
      .nav.scrolled .nav-links a, .nav.scrolled .nav-hamburger span { color: var(--navy); background: var(--navy); }
      .nav.scrolled .nav-links a { background: transparent; }
      .nav-links { display: flex; gap: 1.7rem; }
      .nav-links a { color: var(--white); text-decoration: none; text-transform: uppercase; letter-spacing: .08em; font-size: .72rem; font-weight: 700; }
      .nav-hamburger { display: none; flex-direction: column; gap: 5px; background: transparent; border: 0; padding: .5rem; }
      .nav-hamburger span { width: 24px; height: 2px; background: var(--white); }
      .mobile-menu { display: none; position: fixed; inset: 0; z-index: 999; background: var(--navy); align-items: center; justify-content: center; flex-direction: column; gap: 2rem; }
      .mobile-menu.active { display: flex; }
      .mobile-menu a { color: var(--white); text-decoration: none; font-family: "Playfair Display", serif; font-size: 1.5rem; }
      .hero { min-height: 100vh; position: relative; display: grid; place-items: center; overflow: hidden; }
      .hero-slides, .hero-slide, .hero-overlay { position: absolute; inset: 0; }
      .hero-slide { opacity: 0; transition: opacity 1.2s ease; }
      .hero-slide.active { opacity: 1; }
      .hero-slide img { width: 100%; height: 100%; object-fit: cover; transform: scale(1.05); transition: transform 8s ease; }
      .hero-slide.active img { transform: scale(1.12); }
      .hero-overlay { background: rgba(26, 53, 87, .62); z-index: 1; }
      .hero-content { position: relative; z-index: 2; max-width: 1000px; text-align: center; padding: 0 1.5rem; color: var(--white); }
      .hero-line { width: 2px; height: 50px; background: var(--white); opacity: .5; margin: 0 auto 2rem; }
      .hero-overline, .section-label { text-transform: uppercase; letter-spacing: .3em; font-size: .7rem; color: var(--blue); font-weight: 800; }
      .hero-overline { color: var(--sky-pale); margin-bottom: 1.6rem; }
      h1, h2, h3 { font-family: "Playfair Display", Georgia, serif; font-weight: 400; line-height: 1.15; margin: 0; color: var(--navy); }
      h1 { color: var(--white); font-size: clamp(2.1rem, 5vw, 4rem); margin-bottom: 1.2rem; }
      h1 em { color: var(--sky-pale); }
      .hero-subtitle { max-width: 650px; margin: 0 auto 2.3rem; color: var(--sky-pale); font-size: 1.05rem; }
      .hero-cta, .cta-final a, .btn-secondary { display: inline-flex; align-items: center; justify-content: center; min-height: 46px; padding: .85rem 2rem; text-decoration: none; text-transform: uppercase; letter-spacing: .14em; font-size: .78rem; font-weight: 800; transition: all .3s ease; }
      .hero-cta, .cta-final a { background: var(--blue); color: var(--white); }
      .hero-cta:hover, .cta-final a:hover { background: var(--white); color: var(--navy); }
      .hero-dots { position: absolute; z-index: 3; bottom: 2rem; display: flex; gap: .7rem; }
      .hero-dot { width: 10px; height: 10px; border-radius: 999px; border: 0; background: rgba(255,255,255,.35); cursor: pointer; }
      .hero-dot.active { background: var(--white); transform: scale(1.25); }
      .section-block, .section-inner { max-width: 1200px; margin: 0 auto; padding: 7rem 2rem; }
      .section-band { background: var(--gray-faint); }
      .audience-section { background: var(--white); }
      .audience-inner { max-width: 1536px; margin: 0 auto; padding: 7rem 1rem; }
      .section-band-blue { background: var(--blue-pale); }
      .section-head { text-align: center; max-width: 720px; margin: 0 auto 3.5rem; }
      .section-head h2, .split h2 { font-size: clamp(2rem, 4vw, 3rem); margin: .8rem 0 1rem; }
      .section-head p:last-child { color: var(--stone); margin: 0; }
      .section-divider { width: 60px; height: 2px; background: var(--blue); margin: 0 auto 1.5rem; }
      .align-left { text-align: left; }
      .split .section-divider { margin-left: 0; }
      .selector-grid, .projects-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.4rem; }
      .selector-card, .project-card { position: relative; overflow: hidden; border-radius: 6px; background: var(--navy); min-height: 320px; text-decoration: none; }
      .selector-card img, .project-card img { width: 100%; height: 100%; object-fit: cover; transition: transform .6s ease; }
      .selector-card:hover img, .project-card:hover img { transform: scale(1.05); }
      .selector-overlay, .project-card div { position: absolute; inset: 0; display: flex; flex-direction: column; align-items: center; justify-content: center; text-align: center; padding: 2rem; color: var(--white); background: rgba(26, 53, 87, .58); transition: background .3s ease; }
      .selector-card:hover .selector-overlay { background: rgba(26, 53, 87, .78); }
      .selector-title { font-family: "Playfair Display", serif; font-size: 1.55rem; margin-bottom: .7rem; }
      .selector-desc { color: var(--sky-pale); font-size: .9rem; max-width: 300px; }
      .selector-arrow { margin-top: 1.2rem; text-transform: uppercase; font-size: .72rem; letter-spacing: .14em; font-weight: 800; }
      .audience-grid, .investment-grid { display: grid; gap: 1.4rem; }
      .audience-grid { grid-template-columns: repeat(2, 1fr); }
      .audience-card { background: var(--navy); overflow: hidden; min-height: 430px; }
      .audience-card img { width: 100%; height: 100%; object-fit: cover; }
      .investment-grid article { background: var(--white); border: 1px solid var(--sky-pale); padding: 2rem; text-align: center; border-radius: 6px; }
      .investment-grid p { color: var(--stone); font-size: .9rem; margin: 0; }
      .pipeline-section { background: var(--navy); color: var(--white); }
      .section-head-dark h2, .section-head-dark p:last-child { color: var(--white); }
      .section-head-dark .section-label { color: var(--sky-pale); }
      .pipeline-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1rem; }
      .pipeline-card { background: var(--white); color: var(--ink); border-radius: 4px; overflow: hidden; min-height: 430px; display: flex; flex-direction: column; }
      .pipeline-copy { padding: 1.25rem; text-align: left; min-height: 158px; }
      .pipeline-copy span { color: var(--blue); text-transform: uppercase; letter-spacing: .12em; font-size: .72rem; font-weight: 800; display: block; margin-bottom: .45rem; }
      .pipeline-copy strong { color: var(--navy); line-height: 1.2; display: block; font-family: "Playfair Display", serif; font-size: 1.45rem; font-weight: 400; }
      .pipeline-copy p { margin: .65rem 0 0; color: var(--ink); font-size: .9rem; line-height: 1.5; }
      .pipeline-card img { width: 100%; flex: 1; object-fit: cover; min-height: 260px; }
      .pipeline-layers { margin-top: 4rem; border-top: 1px solid rgba(197, 213, 232, .28); padding-top: 3rem; }
      .pipeline-layers-head { max-width: 720px; margin: 0 auto 2rem; text-align: center; }
      .pipeline-layers-head h3 { color: var(--white); font-size: clamp(1.8rem, 3vw, 2.5rem); margin-top: .5rem; }
      .pipeline-layer-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1rem; }
      .pipeline-layer-card { position: relative; min-height: 280px; overflow: hidden; background: var(--navy); border-radius: 4px; }
      .pipeline-layer-card img { width: 100%; height: 100%; object-fit: cover; opacity: .82; transition: transform .5s ease, opacity .5s ease; }
      .pipeline-layer-card:hover img { transform: scale(1.04); opacity: 1; }
      .pipeline-layer-card div { position: absolute; inset: 0; display: flex; flex-direction: column; justify-content: flex-end; padding: 1.25rem; background: linear-gradient(to top, rgba(26, 53, 87, .92), rgba(26, 53, 87, .12)); }
      .pipeline-layer-card strong { color: var(--white); font-family: "Playfair Display", serif; font-size: 1.35rem; line-height: 1.15; font-weight: 400; }
      .pipeline-layer-card p { color: var(--sky-pale); font-size: .84rem; line-height: 1.45; margin: .55rem 0 0; }
      .split { display: grid; grid-template-columns: 1fr 1fr; gap: 3rem; align-items: center; }
      .split p { color: var(--stone); }
      .tipo-selector, .filters { display: flex; gap: .75rem; flex-wrap: wrap; margin: 1.5rem 0; }
      .tipo-btn, .filter-btn { border: 1px solid var(--sky-pale); background: var(--white); color: var(--stone); padding: .55rem 1rem; border-radius: 4px; cursor: pointer; font-weight: 700; }
      .tipo-btn.active, .tipo-btn:hover, .filter-btn.active, .filter-btn:hover { background: var(--blue); color: var(--white); border-color: var(--blue); }
      .stats { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1rem; margin: 2rem 0; }
      .stats div { background: var(--blue-pale); text-align: center; padding: 1rem; border-radius: 4px; }
      .stats strong { display: block; font-family: "Playfair Display", serif; color: var(--navy); font-size: 1.7rem; }
      .stats span { display: block; color: var(--stone); text-transform: uppercase; letter-spacing: .08em; font-size: .7rem; }
      .btn-secondary { color: var(--blue); border: 1px solid var(--blue); }
      .btn-secondary:hover { background: var(--blue); color: var(--white); }
      .case-image { width: 100%; aspect-ratio: 4 / 3; object-fit: cover; border-radius: 6px; }
      .filters { justify-content: center; }
      .project-card.hidden { display: none; }
      .project-card div { inset: auto 0 0; align-items: flex-start; text-align: left; background: linear-gradient(to top, rgba(26,53,87,.92), transparent); }
      .project-card h3 { color: var(--white); font-size: 1.3rem; }
      .project-card p { color: var(--sky-pale); margin: .2rem 0 0; }
      .investment-grid { grid-template-columns: repeat(3, 1fr); }
      .investment-grid strong { display: block; font-family: "Playfair Display", serif; color: var(--navy); font-size: 2.6rem; }
      .investment-grid span { color: var(--stone); font-weight: 800; display: block; margin-bottom: .8rem; }
      .chart { display: flex; justify-content: center; align-items: end; gap: 2rem; min-height: 250px; background: var(--white); border: 1px solid var(--sky-pale); border-radius: 6px; padding: 2rem; margin: 3rem auto; max-width: 760px; }
      .bar-group { width: 90px; text-align: center; display: grid; justify-items: center; align-items: end; height: 190px; }
      .bar-group span { color: var(--navy); font-weight: 800; }
      .bar { width: 100%; height: 0; background: var(--blue); border-radius: 4px 4px 0 0; transition: height 1s ease; }
      .bar.visible { height: var(--bar-height); }
      .bar-group small { color: var(--stone); font-size: .72rem; }
      .center { text-align: center; }
      .cta-final { background: var(--navy); color: var(--white); text-align: center; padding: 7rem 2rem; }
      .cta-final div { max-width: 720px; margin: 0 auto; }
      .cta-final h2 { color: var(--white); font-size: clamp(2rem, 4vw, 3rem); }
      .cta-final p { color: var(--sky-pale); margin: 1rem auto 2rem; max-width: 620px; }
      .central-message { background: var(--gray-faint); text-align: center; padding: 6rem 2rem; }
      .central-message blockquote { max-width: 860px; margin: 0 auto 1rem; font-family: "Playfair Display", serif; color: var(--navy); font-size: clamp(1.3rem, 3vw, 2rem); font-style: italic; line-height: 1.45; }
      .central-message p { color: var(--blue); font-weight: 800; letter-spacing: .2em; font-size: .75rem; }
      footer { text-align: center; padding: 3rem 2rem; border-top: 1px solid var(--sky-pale); display: grid; justify-items: center; gap: .9rem; }
      footer img { width: 150px; height: auto; display: block; }
      footer span { color: var(--stone); font-size: .78rem; }
      .reveal { opacity: 0; transform: translateY(28px); transition: opacity .7s ease, transform .7s ease; }
      .reveal.visible { opacity: 1; transform: translateY(0); }
      @media (max-width: 1100px) {
        .pipeline-grid { grid-template-columns: repeat(2, 1fr); }
        .pipeline-layer-grid { grid-template-columns: repeat(2, 1fr); }
      }
      @media (max-width: 900px) {
        .nav { padding-inline: 1.25rem; }
        .nav-links { display: none; }
        .nav-hamburger { display: flex; }
        .selector-grid, .projects-grid, .investment-grid, .split { grid-template-columns: 1fr; }
        .section-block, .section-inner { padding: 5rem 1.25rem; }
        .audience-inner { padding: 5rem 1rem; }
        .audience-card { min-height: 360px; }
      }
      @media (max-width: 640px) {
        .audience-grid, .pipeline-grid, .stats { grid-template-columns: 1fr; }
        .pipeline-layer-grid { grid-template-columns: 1fr; }
        .pipeline-card { min-height: 380px; }
        .audience-grid { gap: .75rem; }
        .audience-card { min-height: 300px; }
        .hero { min-height: 92vh; }
        .chart { gap: .8rem; padding-inline: 1rem; }
        .bar-group { width: 64px; }
      }
    </style>

    <script is:inline>
      const nav = document.getElementById('mainNav');
      const progress = document.getElementById('scrollProgress');
      const menu = document.getElementById('mobileMenu');
      const hamburger = document.getElementById('hamburger');

      function updateScrollUi() {
        nav?.classList.toggle('scrolled', window.scrollY > 50);
        const max = document.documentElement.scrollHeight - window.innerHeight;
        progress.style.width = max > 0 ? `${(window.scrollY / max) * 100}%` : '0%';
      }
      window.addEventListener('scroll', updateScrollUi, { passive: true });
      updateScrollUi();

      hamburger?.addEventListener('click', () => {
        const open = menu?.classList.toggle('active');
        hamburger.setAttribute('aria-expanded', String(open));
      });
      menu?.querySelectorAll('a').forEach((link) => link.addEventListener('click', () => {
        menu.classList.remove('active');
        hamburger?.setAttribute('aria-expanded', 'false');
      }));

      const slides = [...document.querySelectorAll('.hero-slide')];
      const dots = [...document.querySelectorAll('.hero-dot')];
      let currentSlide = 0;
      function goToSlide(index) {
        slides[currentSlide]?.classList.remove('active');
        dots[currentSlide]?.classList.remove('active');
        currentSlide = index;
        slides[currentSlide]?.classList.add('active');
        dots[currentSlide]?.classList.add('active');
      }
      let slideInterval = setInterval(() => goToSlide((currentSlide + 1) % slides.length), 5000);
      dots.forEach((dot) => dot.addEventListener('click', () => {
        clearInterval(slideInterval);
        goToSlide(Number(dot.dataset.slide));
        slideInterval = setInterval(() => goToSlide((currentSlide + 1) % slides.length), 5000);
      }));

      const revealObserver = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) entry.target.classList.add('visible');
        });
      }, { threshold: 0.12 });
      document.querySelectorAll('.reveal').forEach((el) => revealObserver.observe(el));

      const casoData = {
        residencial: {
          title: 'Residencial de Lujo',
          desc: 'Desarrollo de villas y apartamentos frente al mar con amenidades premium. Masterplan integrado con acceso directo a playa, zonas verdes y espacios comunes de alto estándar.',
          stats: ['120', '45%', '18'],
          labels: ['Unidades', 'ROI estimado', 'Meses ejecución'],
        },
        hoteleria: {
          title: 'Resort Hotelero',
          desc: 'Hotel 5 estrellas con 200 habitaciones, spa, restaurantes y acceso directo a playa. Operado por marca internacional con gestión profesionalizada.',
          stats: ['200', '38%', '24'],
          labels: ['Habitaciones', 'ROI estimado', 'Meses ejecución'],
        },
        comercial: {
          title: 'Centro Comercial Mixto',
          desc: 'Espacio comercial con retail, oficinas y áreas de entretenimiento. Ubicación estratégica en zona de alta demanda con proyección de crecimiento.',
          stats: ['15K', '32%', '14'],
          labels: ['m² construidos', 'ROI estimado', 'Meses ejecución'],
        },
      };
      document.querySelectorAll('.tipo-btn').forEach((btn) => btn.addEventListener('click', () => {
        document.querySelectorAll('.tipo-btn').forEach((b) => b.classList.remove('active'));
        btn.classList.add('active');
        const data = casoData[btn.dataset.tipo];
        document.getElementById('casoTitle').textContent = data.title;
        document.getElementById('casoDesc').textContent = data.desc;
        document.getElementById('stat1').textContent = data.stats[0];
        document.getElementById('stat2').textContent = data.stats[1];
        document.getElementById('stat3').textContent = data.stats[2];
        document.getElementById('statLabel1').textContent = data.labels[0];
        document.getElementById('statLabel2').textContent = data.labels[1];
        document.getElementById('statLabel3').textContent = data.labels[2];
      }));

      document.querySelectorAll('.filter-btn').forEach((btn) => btn.addEventListener('click', () => {
        document.querySelectorAll('.filter-btn').forEach((b) => b.classList.remove('active'));
        btn.classList.add('active');
        const filter = btn.dataset.filter;
        document.querySelectorAll('.project-card').forEach((card) => {
          card.classList.toggle('hidden', filter !== 'all' && card.dataset.category !== filter);
        });
      }));

      const metricObserver = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return;
          const counter = entry.target;
          const target = Number(counter.dataset.target);
          let current = 0;
          const timer = setInterval(() => {
            current += target / 55;
            if (current >= target) {
              counter.textContent = `${target}${target === 650 ? 'M' : '+'}`;
              clearInterval(timer);
            } else {
              counter.textContent = String(Math.floor(current));
            }
          }, 24);
          metricObserver.unobserve(counter);
        });
      }, { threshold: .5 });
      document.querySelectorAll('.counter').forEach((counter) => metricObserver.observe(counter));

      const chartObserver = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return;
          entry.target.querySelectorAll('.bar').forEach((bar) => bar.classList.add('visible'));
          chartObserver.unobserve(entry.target);
        });
      }, { threshold: .3 });
      document.querySelectorAll('.chart').forEach((chart) => chartObserver.observe(chart));
    </script>
  </body>
</html>
