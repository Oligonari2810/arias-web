---
import Layout from '../layouts/Layout.astro';

const heroImg = 'https://images.unsplash.com/photo-1486406146926-c627a92ad1ab?w=2400&auto=format&fit=crop&q=80';
const craftImg = 'https://images.unsplash.com/photo-1504307651254-35680f356dfd?w=1400&auto=format&fit=crop&q=80';
const materialImg = 'https://images.unsplash.com/photo-1541888946425-d81bb19240f5?w=1400&auto=format&fit=crop&q=80';
const detailImg = 'https://images.unsplash.com/photo-1512917774080-9991f1c4c750?w=1400&auto=format&fit=crop&q=80';
const archImg = 'https://images.unsplash.com/photo-1523413651479-597eb2da0ad6?w=1400&auto=format&fit=crop&q=80';
const trainingImg = 'https://images.unsplash.com/photo-1581094288338-2314dddb7ece?w=1600&auto=format&fit=crop&q=80';
const tropicImg = 'https://images.unsplash.com/photo-1540541338287-41700207dee6?w=2000&auto=format&fit=crop&q=80';
---
<Layout>
  <!-- HERO FULL-BLEED -->
  <section class="relative h-[90vh] min-h-[680px] overflow-hidden">
    <img src={heroImg} alt="Fachada arquitectónica con sistemas constructivos Fassa Bortolo" class="absolute inset-0 w-full h-full object-cover" loading="eager" />
    <div class="absolute inset-0 bg-gradient-to-b from-navy/40 via-navy/55 to-navy/90"></div>
    <div class="relative z-10 h-full max-w-7xl mx-auto px-6 flex flex-col justify-end pb-24">
      <div class="max-w-5xl">
        <p class="text-xs tracking-[0.3em] uppercase text-sky-pale font-semibold mb-4">Santo Domingo · República Dominicana</p>
        <p class="text-white text-2xl md:text-3xl mb-8" style="font-family: 'Fraunces', serif; font-weight: 500; letter-spacing: -0.01em;">
          Arias Group Caribe
        </p>
        <h1 class="text-white text-5xl md:text-7xl lg:text-[5.25rem] leading-[1] mb-8" style="font-family: 'Fraunces', serif; font-weight: 400;">
          Acompañamiento técnico desde el diseño.<br/>
          <em class="italic text-sky-pale font-normal">Formación certificada</em> para la obra.
        </h1>
        <p class="text-lg md:text-xl text-sky-pale max-w-2xl leading-relaxed mb-10">
          Especificamos, importamos y supervisamos sistemas Fassa Bortolo en República Dominicana.
        </p>
        <div class="flex flex-wrap gap-4">
          <a href="https://wa.me/18494754442" target="_blank" rel="noopener" class="bg-white text-navy px-8 py-4 text-sm font-semibold tracking-wide hover:bg-sky-pale transition-colors inline-flex items-center gap-2">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.5 14.4c-.3-.1-1.7-.8-2-.9-.3-.1-.5-.1-.7.1-.2.3-.8.9-1 1.1-.2.2-.4.2-.7.1-.3-.1-1.2-.4-2.3-1.4-.9-.8-1.4-1.7-1.6-2-.2-.3 0-.5.1-.6.1-.1.3-.3.4-.5.1-.2.2-.3.3-.5.1-.2 0-.4 0-.5 0-.1-.7-1.7-1-2.3-.3-.6-.5-.5-.7-.5h-.6c-.2 0-.5.1-.8.4-.3.3-1 1-1 2.4s1 2.8 1.2 3c.1.2 2.1 3.2 5.1 4.5.7.3 1.3.5 1.7.6.7.2 1.4.2 1.9.1.6-.1 1.7-.7 2-1.4.2-.7.2-1.2.2-1.4-.1-.2-.3-.3-.6-.4zM12 2C6.5 2 2 6.5 2 12c0 1.8.5 3.4 1.3 4.8L2 22l5.3-1.4c1.4.8 3 1.2 4.7 1.2 5.5 0 10-4.5 10-10S17.5 2 12 2zm0 18.2c-1.6 0-3-.4-4.3-1.2l-.3-.2-3.1.8.8-3-.2-.3C4 15 3.5 13.5 3.5 12c0-4.7 3.8-8.5 8.5-8.5s8.5 3.8 8.5 8.5-3.8 8.2-8.5 8.2z"/></svg>
            Escribir por WhatsApp
          </a>
          <a href="/sistemas" class="border border-white/60 text-white px-8 py-4 text-sm font-semibold tracking-wide hover:bg-white hover:text-navy transition-colors">
            Ver sistemas
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- MANIFIESTO -->
  <section class="max-w-5xl mx-auto px-6 py-32 text-center">
    <p class="text-xs tracking-[0.3em] uppercase text-stone-blue font-semibold mb-10">El problema que resolvemos</p>
    <p class="text-3xl md:text-5xl leading-tight text-navy" style="font-family: 'Fraunces', serif; font-weight: 400;">
      Importar producto europeo es la parte fácil.<br/>
      <em class="italic text-blue">Hacerlo funcionar en obra dominicana</em><br/>
      es el trabajo que nadie asume.
    </p>
  </section>

  <!-- DOBLE PROMESA — PESO VISUAL EQUIVALENTE AL GRID DE SISTEMAS -->
  <section class="bg-gray-faint">
    <div class="max-w-7xl mx-auto px-6 py-24">
      <div class="mb-16">
        <p class="text-xs tracking-[0.3em] uppercase text-stone-blue font-semibold mb-4">Las dos promesas</p>
        <h2 class="text-4xl md:text-5xl max-w-3xl leading-tight" style="font-family: 'Fraunces', serif; font-weight: 500;">
          Un solo compromiso. <em class="italic text-blue font-normal">Dos momentos.</em>
        </h2>
      </div>

      <div class="grid md:grid-cols-2 gap-6">
        <!-- Antes -->
        <div class="group aspect-[5/4] relative overflow-hidden bg-navy">
          <img src={materialImg} alt="Especificación técnica con arquitectos e ingenieros" class="absolute inset-0 w-full h-full object-cover opacity-85 group-hover:opacity-100 group-hover:scale-105 transition-all duration-700" loading="lazy" />
          <div class="absolute inset-0 bg-gradient-to-t from-navy via-navy/50 to-navy/20"></div>
          <div class="absolute inset-0 p-10 md:p-12 flex flex-col justify-between text-white">
            <div>
              <span class="text-xs font-mono tracking-widest text-sky-pale">ANTES · ESPECIFICACIÓN</span>
            </div>
            <div>
              <h3 class="text-3xl md:text-4xl text-white mb-4 max-w-sm" style="font-family: 'Fraunces', serif; font-weight: 500;">
                Acompañamiento técnico desde el diseño
              </h3>
              <p class="text-sm text-sky-pale leading-relaxed max-w-md">
                Nos sentamos con arquitectos e ingenieros antes de que existan los planos. Especificamos los sistemas correctos desde el principio — no compitiendo por precio al final.
              </p>
            </div>
          </div>
        </div>
        <!-- Durante -->
        <a href="/formacion" class="group aspect-[5/4] relative overflow-hidden bg-navy block">
          <img src={trainingImg} alt="Programa de formación certificada para aplicadores Fassa" class="absolute inset-0 w-full h-full object-cover opacity-85 group-hover:opacity-100 group-hover:scale-105 transition-all duration-700" loading="lazy" />
          <div class="absolute inset-0 bg-gradient-to-t from-navy via-navy/50 to-navy/20"></div>
          <div class="absolute inset-0 p-10 md:p-12 flex flex-col justify-between text-white">
            <div class="flex items-center justify-between">
              <span class="text-xs font-mono tracking-widest text-sky-pale">DURANTE · EJECUCIÓN</span>
              <span class="text-xs font-mono tracking-widest text-sky-pale border border-sky-pale/50 px-3 py-1">Único en RD</span>
            </div>
            <div>
              <h3 class="text-3xl md:text-4xl text-white mb-4 max-w-sm" style="font-family: 'Fraunces', serif; font-weight: 500;">
                Formación certificada de aplicadores
              </h3>
              <p class="text-sm text-sky-pale leading-relaxed max-w-md">
                Como canal oficial Fassa Bortolo, certificamos aplicadores locales con título europeo. El riesgo no está en el material importado — está en que lo pongan mal. Nosotros cerramos esa brecha.
              </p>
              <span class="inline-block mt-5 text-xs text-white border-b border-sky-pale pb-0.5">Conocer el programa →</span>
            </div>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- FASSATHERM EN EL CARIBE -->
  <section class="relative overflow-hidden">
    <img src={tropicImg} alt="Paisaje tropical del Caribe — clima para el que se diseñó Fassatherm DNA" class="absolute inset-0 w-full h-full object-cover" loading="lazy" />
    <div class="absolute inset-0 bg-navy/85"></div>
    <div class="relative z-10 max-w-7xl mx-auto px-6 py-24 text-white">
      <p class="text-xs tracking-[0.3em] uppercase text-sky-pale font-semibold mb-4">Sistema diseñado para el trópico</p>
      <h2 class="text-4xl md:text-5xl max-w-3xl leading-tight mb-5" style="font-family: 'Fraunces', serif; font-weight: 500;">
        Europa aplicada <em class="italic text-sky-pale font-normal">al trópico.</em>
      </h2>
      <p class="text-base md:text-lg text-sky-pale max-w-2xl leading-relaxed mb-14">
        Los sistemas de la competencia se diseñan para el invierno europeo. Nosotros traemos las líneas específicas pensadas para las condiciones que aquí sí importan.
      </p>
      <div class="grid md:grid-cols-3 gap-10">
        {[
          {
            n: '01',
            t: 'Humedad tropical',
            d: 'Morteros con cal hidráulica natural (línea A 96 Resphira, NHL 3.5). Transpirabilidad superior — evitan condensaciones internas y moho en ambientes >80% HR.'
          },
          {
            n: '02',
            t: 'Salinidad costera',
            d: 'Morteros hidrófugos y flexibles resistentes a la degradación por sal marina. Pensados para Punta Cana, La Romana, Puerto Plata y cualquier zona a menos de 5 km de costa.'
          },
          {
            n: '03',
            t: 'Ciclos térmicos y viento',
            d: 'El sistema Fassatherm DNA absorbe movimientos de dilatación sin fisurarse. Resistencia al impacto certificada — argumento técnico frente a huracanes de categoría alta.'
          },
        ].map(b => (
          <div class="border-t border-blue pt-6">
            <span class="text-xs font-mono tracking-widest text-sky-pale">{b.n}</span>
            <h3 class="text-2xl text-white mt-3 mb-4" style="font-family: 'Fraunces', serif; font-weight: 500;">{b.t}</h3>
            <p class="text-sm text-sky-pale leading-relaxed">{b.d}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CATEGORÍAS EDITORIAL GRID -->
  <section class="bg-white">
    <div class="max-w-7xl mx-auto px-6 py-24">
      <div class="flex flex-col md:flex-row md:items-end justify-between mb-16 gap-6">
        <div>
          <p class="text-xs tracking-[0.3em] uppercase text-stone-blue font-semibold mb-4">Portafolio técnico</p>
          <h2 class="text-4xl md:text-5xl max-w-2xl leading-tight" style="font-family: 'Fraunces', serif; font-weight: 500;">
            Ocho familias, <em class="italic text-blue font-normal">195 referencias.</em>
          </h2>
        </div>
        <a href="/catalogo" class="text-sm font-semibold text-navy border-b-2 border-blue pb-1 hover:text-blue transition-colors w-fit">
          Ver catálogo completo →
        </a>
      </div>

      <div class="grid md:grid-cols-12 gap-6">
        <a href="/sistemas" class="group md:col-span-7 aspect-[4/3] relative overflow-hidden bg-navy block">
          <img src={materialImg} alt="Placas Gypsotech — sistemas constructivos europeos" class="absolute inset-0 w-full h-full object-cover opacity-90 group-hover:opacity-100 group-hover:scale-105 transition-all duration-700" loading="lazy" />
          <div class="absolute inset-0 bg-gradient-to-t from-navy/90 via-navy/30 to-transparent"></div>
          <div class="absolute bottom-0 left-0 p-10 text-white">
            <span class="text-xs font-mono tracking-wider text-sky-pale">01</span>
            <h3 class="text-3xl md:text-4xl text-white mt-2" style="font-family: 'Fraunces', serif; font-weight: 500;">Placas Gypsotech</h3>
            <p class="text-sm text-sky-pale mt-3 max-w-md">STD · Aqua H2 · EXTERNA Light · GypsoLIGNUM · 61 formatos</p>
          </div>
        </a>
        <a href="/sistemas" class="group md:col-span-5 aspect-[4/3] relative overflow-hidden bg-navy block">
          <img src={detailImg} alt="Morteros SATE Fassatherm para fachadas" class="absolute inset-0 w-full h-full object-cover opacity-90 group-hover:opacity-100 group-hover:scale-105 transition-all duration-700" loading="lazy" />
          <div class="absolute inset-0 bg-gradient-to-t from-navy/90 via-navy/30 to-transparent"></div>
          <div class="absolute bottom-0 left-0 p-10 text-white">
            <span class="text-xs font-mono tracking-wider text-sky-pale">02</span>
            <h3 class="text-3xl md:text-4xl text-white mt-2" style="font-family: 'Fraunces', serif; font-weight: 500;">Morteros SATE</h3>
            <p class="text-sm text-sky-pale mt-3">Fassatherm · adhesivos · acabados</p>
          </div>
        </a>
        <a href="/sistemas" class="group md:col-span-4 aspect-[4/3] relative overflow-hidden bg-navy block">
          <img src={craftImg} alt="Perfilería galvanizada Z1 Z2 Z275 — resistente a salinidad costera" class="absolute inset-0 w-full h-full object-cover opacity-90 group-hover:opacity-100 group-hover:scale-105 transition-all duration-700" loading="lazy" />
          <div class="absolute inset-0 bg-gradient-to-t from-navy/90 via-navy/40 to-transparent"></div>
          <div class="absolute bottom-0 left-0 p-8 text-white">
            <span class="text-xs font-mono tracking-wider text-sky-pale">03</span>
            <h3 class="text-2xl text-white mt-2" style="font-family: 'Fraunces', serif; font-weight: 500;">Perfilería</h3>
            <p class="text-xs text-sky-pale mt-2">Z1 · Z2 · galvanizado Z275</p>
          </div>
        </a>
        <a href="/sistemas" class="group md:col-span-4 aspect-[4/3] relative overflow-hidden bg-navy block">
          <img src={archImg} alt="Fassajoint y pastas de acabado para juntas" class="absolute inset-0 w-full h-full object-cover opacity-90 group-hover:opacity-100 group-hover:scale-105 transition-all duration-700" loading="lazy" />
          <div class="absolute inset-0 bg-gradient-to-t from-navy/90 via-navy/40 to-transparent"></div>
          <div class="absolute bottom-0 left-0 p-8 text-white">
            <span class="text-xs font-mono tracking-wider text-sky-pale">04</span>
            <h3 class="text-2xl text-white mt-2" style="font-family: 'Fraunces', serif; font-weight: 500;">Pastas y juntas</h3>
            <p class="text-xs text-sky-pale mt-2">Fassajoint · Gypsofiller · Gypsomaf</p>
          </div>
        </a>
        <a href="/catalogo" class="group md:col-span-4 aspect-[4/3] bg-navy flex flex-col justify-between p-8 text-white hover:bg-blue transition-colors">
          <span class="text-xs font-mono tracking-wider text-sky-pale">+</span>
          <div>
            <h3 class="text-2xl text-white mb-3" style="font-family: 'Fraunces', serif; font-weight: 500;">Accesorios, trampillas y tornillería</h3>
            <span class="text-xs text-sky-pale border-b border-sky-pale pb-0.5">Ver catálogo completo →</span>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- PULL QUOTE (claim de marca, sin comillas) -->
  <section class="max-w-5xl mx-auto px-6 py-32 text-center">
    <p class="text-2xl md:text-3xl leading-snug text-navy" style="font-family: 'Fraunces', serif; font-weight: 400;">
      En Arias Group trabajamos con un sistema completo bajo una sola marca. <em class="italic text-blue">Una sola responsabilidad técnica</em> desde la especificación hasta el acabado final.
    </p>
    <p class="mt-8 text-sm tracking-wider uppercase text-stone-blue font-semibold">Principio fundacional · Arias Group Caribe</p>
  </section>

  <!-- NÚMEROS / CONFIANZA -->
  <section class="bg-navy text-white">
    <div class="max-w-7xl mx-auto px-6 py-24 grid md:grid-cols-4 gap-10">
      {[
        { n: '1', l: 'Sistema integral.\nUn solo responsable técnico.' },
        { n: '4', l: 'Condiciones tropicales\ncubiertas por diseño' },
        { n: '195', l: 'Referencias\nen catálogo' },
        { n: 'CE', l: 'Marcado europeo\npor fabricante Fassa Bortolo' },
      ].map(s => (
        <div class="border-t border-blue pt-6">
          <div class="text-5xl md:text-6xl mb-4" style="font-family: 'Fraunces', serif; font-weight: 400;">{s.n}</div>
          <p class="text-sm text-sky-pale whitespace-pre-line leading-relaxed">{s.l}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- CTA FINAL -->
  <section class="max-w-5xl mx-auto px-6 py-32 text-center">
    <h2 class="text-4xl md:text-6xl leading-tight mb-8" style="font-family: 'Fraunces', serif; font-weight: 400;">
      ¿Tienes un proyecto<br/>
      <em class="italic text-blue">en marcha?</em>
    </h2>
    <p class="text-lg text-stone-blue max-w-xl mx-auto mb-10 leading-relaxed">
      Envíanos planos o especificaciones por WhatsApp. Devolvemos presupuesto técnico detallado en 48&nbsp;horas.
    </p>
    <div class="flex flex-wrap gap-4 justify-center">
      <a href="https://wa.me/18494754442" target="_blank" rel="noopener" class="inline-flex items-center gap-2 bg-navy text-white px-10 py-5 text-sm font-semibold tracking-wider hover:bg-blue transition-colors">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.5 14.4c-.3-.1-1.7-.8-2-.9-.3-.1-.5-.1-.7.1-.2.3-.8.9-1 1.1-.2.2-.4.2-.7.1-.3-.1-1.2-.4-2.3-1.4-.9-.8-1.4-1.7-1.6-2-.2-.3 0-.5.1-.6.1-.1.3-.3.4-.5.1-.2.2-.3.3-.5.1-.2 0-.4 0-.5 0-.1-.7-1.7-1-2.3-.3-.6-.5-.5-.7-.5h-.6c-.2 0-.5.1-.8.4-.3.3-1 1-1 2.4s1 2.8 1.2 3c.1.2 2.1 3.2 5.1 4.5.7.3 1.3.5 1.7.6.7.2 1.4.2 1.9.1.6-.1 1.7-.7 2-1.4.2-.7.2-1.2.2-1.4-.1-.2-.3-.3-.6-.4zM12 2C6.5 2 2 6.5 2 12c0 1.8.5 3.4 1.3 4.8L2 22l5.3-1.4c1.4.8 3 1.2 4.7 1.2 5.5 0 10-4.5 10-10S17.5 2 12 2zm0 18.2c-1.6 0-3-.4-4.3-1.2l-.3-.2-3.1.8.8-3-.2-.3C4 15 3.5 13.5 3.5 12c0-4.7 3.8-8.5 8.5-8.5s8.5 3.8 8.5 8.5-3.8 8.2-8.5 8.2z"/></svg>
        Enviar por WhatsApp
      </a>
      <a href="mailto:info@ariasgroupcaribe.com" class="inline-block border border-navy text-navy px-10 py-5 text-sm font-semibold tracking-wider hover:bg-navy hover:text-white transition-colors">
        Enviar por email
      </a>
    </div>
  </section>
</Layout>
